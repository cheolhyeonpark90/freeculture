---
import '../style.css';
interface Props {
	title?: string;
	description?: string;
}

const { 
  title = "무료한 문화생활 – 서울·경기·부산 전시·공연·축제 일정 모아보기", 
  description = "서울·경기·부산 등 전국의 무료·유료 전시·공연·축제 정보를 지역·카테고리·날짜별로 빠르게 찾을 수 있는 문화 이벤트 큐레이션 플랫폼입니다."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
<head>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-7VG4XVH2WW"></script>
    <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());

        gtag('config', 'G-7VG4XVH2WW');
    </script>
    <meta name="naver-site-verification" content="bc73dd74b2c5632633f991140b87f8ba7da44516" />
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <!-- SEO Meta Tags -->
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="전시, 공연, 축제, 무료, 유료, 문화정보, 서울 문화, 경기 문화, 부산 문화, 문화 행사" />
    <link rel="canonical" href="https://freeculture.xyz/" />
    <meta name="theme-color" content="#6da8ff" />
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://freeculture.xyz/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://freeculture.xyz/og-cover.png" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://freeculture.xyz/og-cover.png" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "무료한 문화생활",
      "url": "https://freeculture.xyz/",
      "description": "서울·경기·부산 등 전국의 무료·유료 전시·공연·축제 정보를 지역·카테고리·날짜별로 빠르게 찾을 수 있는 문화 이벤트 큐레이션 플랫폼입니다.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://freeculture.xyz/?search={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    })} />
    
    <link rel="icon" href="/favicon.ico">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">
</head>
<body>
    <div id="initial-loader">
        <div class="spinner"></div>
    </div>

    <header>
        <div class="content-wrapper">
            <a href="/" style="text-decoration: none; color: inherit;">
                <h1>무료한 문화생활</h1>
            </a>
        </div>
    </header>

    <slot />

</body>
</html>
